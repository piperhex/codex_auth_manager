  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "check:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check && cargo test --manifest-path src-tauri/Cargo.toml",
    "check": "npm run build && npm run check:rust",
    "commitlint": "commitlint",
    "prepare": "husky",
    "preview": "vite preview",
    "tauri": "tauri",
    "dev:app": "tauri dev",
    "build:app": "tauri build",
    "build:app:mac": "tauri build --target universal-apple-darwin",
    "release": "node scripts/tag-release.mjs",
    "release-beta": "node scripts/tag-release.mjs --beta"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-dialog": "^2.4.0",
    "@tauri-apps/plugin-opener": "^2.5.0",
    "antd": "^5.29.3",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@tauri-apps/cli": "^2.8.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "husky": "^9.1.7",
    "typescript": "~5.6.3",
    "vite": "^6.0.5"
  }
}
