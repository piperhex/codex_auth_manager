{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "@codex-switch/desktop",
  "projectType": "application",
  "sourceRoot": "apps/desktop/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/dist"
      ],
      "options": {
        "command": "npm run build -w @codex-switch/desktop"
      }
    },
    "check": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/dist"
      ],
      "options": {
        "command": "npm run check -w @codex-switch/desktop"
      }
    },
    "check:rust": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/src-tauri/target"
      ],
      "options": {
        "command": "npm run check:rust -w @codex-switch/desktop"
      }
    },
    "build:app": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/src-tauri/target"
      ],
      "options": {
        "command": "npm run build:app -w @codex-switch/desktop"
      }
    }
  }
}
