{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "@codex-switch/admin-ui",
  "projectType": "application",
  "sourceRoot": "apps/admin-ui/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/apps/admin/public"
      ],
      "options": {
        "command": "npm run build -w @codex-switch/admin-ui"
      }
    },
    "check": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/apps/admin/public"
      ],
      "options": {
        "command": "npm run check -w @codex-switch/admin-ui"
      }
    }
  }
}
