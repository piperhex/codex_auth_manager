{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "@codex-switch/backend",
  "projectType": "application",
  "sourceRoot": "apps/admin/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/dist"
      ],
      "options": {
        "command": "npm run build -w @codex-switch/backend"
      }
    },
    "check": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/dist"
      ],
      "options": {
        "command": "npm run check -w @codex-switch/backend"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/coverage"
      ],
      "options": {
        "command": "npm run test -w @codex-switch/backend"
      }
    },
    "test:typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run test:typecheck -w @codex-switch/backend"
      }
    }
  }
}
