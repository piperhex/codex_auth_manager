NODE_ENV=development
LISTEN_PORT=8080

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=codex_switch
POSTGRES_PASSWORD=codex_switch
POSTGRES_DB=codex_switch
POSTGRES_DB_SYNCHRONIZE=true

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_ACCESS_EXPIRES=15m
REFRESH_TOKEN_TTL_SECONDS=2592000
# Required in production. Generate with: openssl rand -hex 32
JWT_REFRESH_SECRET=

# Kong JWT plugin maps the access token iss claim to a Consumer JWT credential key.
KONG_JWT_KEY=codex-switch
# Required in production and must match the Kong JWT credential secret.
KONG_JWT_SECRET=
